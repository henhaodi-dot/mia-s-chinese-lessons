  },
  {
    "id": "food_03",
    "topic": "food",
    "pandaQuestion": "你渴了想喝什么？",
    "pandaQuestionAudioKey": "dialogue_food_03_q",
    "answers": [
      {
        "text": "我想喝水",
        "audioKey": "dialogue_food_03_a1",
        "emoji": "💧"
      },
      {
        "text": "我想喝牛奶",
        "audioKey": "dialogue_food_03_a2",
