      {
        "text": "我自己想办法",
        "audioKey": "dialogue_feeling_03_a1",
        "emoji": "💪"
      },
      {
        "text": "我去问老师",
        "audioKey": "dialogue_feeling_03_a2",
        "emoji": "🙋"
      },
      {
        "text": "我找朋友帮忙",
        "audioKey": "dialogue_feeling_03_a3",
        "emoji": "🤝"
      }
    ],
    "pandaFollowUps": {
      "dialogue_feeling_03_a1": {
        "text": "愿意自己动脑筋，很棒。",
        "audioKey": "dialogue_feeling_03_f1"
