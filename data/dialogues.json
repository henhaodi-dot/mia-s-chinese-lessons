      "dialogue_feeling_03_a2": {
        "text": "不懂就问，是聪明的做法。",
        "audioKey": "dialogue_feeling_03_f2"
      },
      "dialogue_feeling_03_a3": {
        "text": "大家一起想，办法更多。",
        "audioKey": "dialogue_feeling_03_f3"
      }
    }
  },
  {
