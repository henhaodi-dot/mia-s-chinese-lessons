  },
  {
    "id": "food_02",
    "topic": "food",
    "pandaQuestion": "你最爱吃的水果是什么？",
    "pandaQuestionAudioKey": "dialogue_food_02_q",
    "answers": [
      {
        "text": "我爱吃香蕉",
        "audioKey": "dialogue_food_02_a1",
        "emoji": "🍌"
      },
      {
        "text": "我爱吃橙子",
        "audioKey": "dialogue_food_02_a2",
        "emoji": "🍊"
      },
      {
        "text": "我爱吃葡萄",
        "audioKey": "dialogue_food_02_a3",
        "emoji": "🍇"
      }
    ],
    "pandaFollowUps": {
      "dialogue_food_02_a1": {
        "text": "香蕉营养好，运动前吃正合适。",
        "audioKey": "dialogue_food_02_f1"
      },
      "dialogue_food_02_a2": {
        "text": "橙子酸甜可口，还有维C。",
        "audioKey": "dialogue_food_02_f2"
      },
      "dialogue_food_02_a3": {
        "text": "葡萄一颗接一颗，真好吃。",
        "audioKey": "dialogue_food_02_f3"
      }
