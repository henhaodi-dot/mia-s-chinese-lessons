      "dialogue_food_01_a2": {
        "text": "米饭配上菜，最香了。",
        "audioKey": "dialogue_food_01_f2"
      },
      "dialogue_food_01_a3": {
        "text": "苹果又甜又脆，好选择！",
        "audioKey": "dialogue_food_01_f3"
      }
