[
  {
    "id": "food_01",
    "topic": "food",
    "pandaQuestion": "你今天想吃什么？",
    "pandaQuestionAudioKey": "dialogue_food_01_q",
    "answers": [
      {
        "text": "我想吃面条",
        "audioKey": "dialogue_food_01_a1",
