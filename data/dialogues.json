  {
    "id": "animal_02",
    "topic": "animals",
    "pandaQuestion": "你想去动物园看什么？",
    "pandaQuestionAudioKey": "dialogue_animal_02_q",
    "answers": [
      {
        "text": "我想看熊猫",
        "audioKey": "dialogue_animal_02_a1",
        "emoji": "🐼"
      },
      {
        "text": "我想看大象",
        "audioKey": "dialogue_animal_02_a2",
        "emoji": "🐘"
      },
      {
        "text": "我想看长颈鹿",
        "audioKey": "dialogue_animal_02_a3",
        "emoji": "🦒"
      }
    ],
    "pandaFollowUps": {
      "dialogue_animal_02_a1": {
        "text": "那是我的亲戚，替我打个招呼！",
        "audioKey": "dialogue_animal_02_f1"
      },
      "dialogue_animal_02_a2": {
        "text": "大象又大又温和，很了不起。",
        "audioKey": "dialogue_animal_02_f2"
      },
      "dialogue_animal_02_a3": {
        "text": "长颈鹿脖子长，能吃到高处的叶子。",
        "audioKey": "dialogue_animal_02_f3"
      }
    }
  },
  {
    "id": "animal_03",
    "topic": "animals",
    "pandaQuestion": "你觉得哪种动物最厉害？",
    "pandaQuestionAudioKey": "dialogue_animal_03_q",
    "answers": [
      {
        "text": "我觉得狮子最厉害",
        "audioKey": "dialogue_animal_03_a1",
        "emoji": "🦁"
      },
      {
        "text": "我觉得老虎最厉害",
        "audioKey": "dialogue_animal_03_a2",
        "emoji": "🐯"
      },
      {
        "text": "我觉得老鹰最厉害",
        "audioKey": "dialogue_animal_03_a3",
        "emoji": "🦅"
      }
    ],
    "pandaFollowUps": {
      "dialogue_animal_03_a1": {
        "text": "狮子是草原之王，很威风。",
        "audioKey": "dialogue_animal_03_f1"
      },
      "dialogue_animal_03_a2": {
        "text": "老虎又快又有力气，确实厉害。",
        "audioKey": "dialogue_animal_03_f2"
      },
      "dialogue_animal_03_a3": {
        "text": "老鹰眼睛很尖，飞得又高又快。",
        "audioKey": "dialogue_animal_03_f3"
      }
    }
  },
  {
    "id": "feeling_01",
    "topic": "feelings",
    "pandaQuestion": "你今天心情怎么样？",
    "pandaQuestionAudioKey": "dialogue_feeling_01_q",
    "answers": [
      {
        "text": "我很开心",
        "audioKey": "dialogue_feeling_01_a1",
        "emoji": "😄"
      },
      {
        "text": "我有点累",
        "audioKey": "dialogue_feeling_01_a2",
        "emoji": "😌"
      },
